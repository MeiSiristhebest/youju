# 前端 API 基础路径
# 开发环境走 Vite 代理 (/api → http://localhost:3001)
# EdgeOne Pages 部署时：
#   - 如果后端也在 EdgeOne Functions 同域下，保持 /api
#   - 如果后端独立部署，改为完整 URL 如 https://api.example.com
# 本地开发默认为 /api，通过 vite.config.ts 代理到 http://localhost:3001
VITE_API_BASE_URL=/api

# 应用名称（可选，用于页面标题等）
# VITE_APP_NAME=有据

# 部署环境标识（可选）
# VITE_ENV=production

# ===== Enable Chat Feature =====
VITE_ENABLE_CHAT=true

# ===== Langfuse Observability =====
# Langfuse 面板地址，用于前端构建"查看 trace"链接
# 默认 https://cloud.langfuse.com（自建部署时改为自建地址）
VITE_LANGFUSE_HOST=https://cloud.langfuse.com
