NODE_ENV=development
PORT=3001

# === AI 配置 ===
AI_API_KEY=
AI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-5.5

# AI 厂商（用于 LLM Provider 工厂选择，默认 openai）
AI_PROVIDER=openai

# AI 调用超时（毫秒）
AI_CALL_TIMEOUT_MS=120000
AI_LIST_MODELS_TIMEOUT_MS=15000
AI_TEST_CONNECTION_TIMEOUT_MS=30000

# Prompt 缓存开关（true/false）
AI_PROMPT_CACHE_ENABLED=true

# === 安全配置 ===
# JWT_SECRET 生产环境必须显式设置！使用默认开发密钥启动会直接报错。
JWT_SECRET=youju-dev-secret-key-change-in-production-please
JWT_EXPIRES_IN=7d
JWT_ALG=HS256
JWT_ISSUER=youju

# === 性能优化配置 ===

# AI 请求并发上限（避免 API 调用超限）
AI_MAX_CONCURRENCY=3

# 分析缓存配置（热门场景预计算）
ANALYSIS_CACHE_TTL_MS=86400000
ANALYSIS_CACHE_MAX_ENTRIES=50

# Prompt 缓存容量
PROMPT_CACHE_ANALYSIS_MAX=50
PROMPT_CACHE_DRAFT_MAX=100
PROMPT_CACHE_EMBEDDING_MAX=200

# Prompt 缓存 TTL（毫秒）
PROMPT_CACHE_ANALYSIS_TTL_MS=21600000
PROMPT_CACHE_DRAFT_TTL_MS=43200000
PROMPT_CACHE_EMBEDDING_TTL_MS=86400000

# Prompt 缓存统计日志间隔（毫秒，默认 30min）
PROMPT_CACHE_STATS_INTERVAL_MS=1800000

# 场景预热（服务启动时预计算预设场景）
ENABLE_SCENARIO_PREHEAT=true

# 后台任务
ENABLE_BACKGROUND_JOBS=true
RUN_JOBS_ON_START=false

# 数据库备份
BACKUP_ON_START=false

# === 数据库配置 ===
DATABASE_PATH=youju.db
# DATABASE_URL=postgresql://user:pass@localhost:5432/youju

# === 速率限制配置 ===
RATE_LIMIT_STORE=memory
# REDIS_URL=redis://localhost:6379
RATE_LIMIT_GENERAL_PER_MIN=120
RATE_LIMIT_AUTH_PER_15MIN=10
RATE_LIMIT_ANALYZE_PER_MIN=10
RATE_LIMIT_URLFETCH_PER_MIN=20
RATE_LIMIT_CHAT_PER_MIN=30

# 速率限制时间窗口（毫秒）
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_AUTH_WINDOW_MS=900000

# ===== RAG Embedding =====
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=https://api.siliconflow.cn/v1
EMBEDDING_MODEL=bge-m3
EMBEDDING_BATCH_SIZE=64

# ===== RAG Reranker =====
RERANKER_API_KEY=
RERANKER_BASE_URL=https://api.siliconflow.cn/v1
RERANKER_MODEL=bge-reranker-v2-m3
RERANKER_MAX_RETRIES=2

# ===== RAG Retrieval =====
VECTOR_SIMILARITY_THRESHOLD=0.65
CHAT_MAX_TOKENS=4096
CHAT_RETRIEVAL_TOP_K=20
CHAT_MAX_STEPS=6

# ===== Langfuse Observability =====
LANGFUSE_SECRET=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# ===== Database Driver =====
DB_DRIVER=sqlite

# ===== Cron Auth =====
CRON_SECRET=

# ===== URL Fetch SSRF Protection =====
URL_FETCH_ALLOWLIST=
URL_FETCH_DENYLIST=
