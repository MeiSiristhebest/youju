{
  "compilerOptions": {
    "target": "ES2023",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "skipLibCheck": true,
    "outDir": "dist-edgeone",
    "rootDir": ".",
    "resolveJsonModule": true,
    "verbatimModuleSyntax": true,
    "noFallthroughCasesInSwitch": true
  },
  "include": [
    "src/**/*",
    "edgeone/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "dist-edgeone",
    "tests",
    "**/*.test.ts",
    "**/*.test.tsx"
  ]
}
